<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" >

    <material name="white">
        <color rgba="1 1 1 1" />
    </material>

    <material name="orange">
        <color rgba="1 0.3 0.1 1"/>
    </material>

    <material name="blue">
        <color rgba="0.2 0.2 1 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <link name="base_footprint" />
    
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 0.0325" rpy="0 0 0" />
    </joint>

    <link name="base_link">
        <inertial>
        <origin xyz="-0.0019055 0.00010735 0.052989" rpy="0 0 0" />
        <mass value="0.64078" />
        <inertia ixx="0.00089929" ixy="-1.4108e-06" ixz="4.4656e-08" iyy="0.00081185" iyz="1.034e-07" izz="0.0014661" />
        </inertial>
        <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <geometry>
            <mesh filename="package://jazzy_gz/meshes/base_link.STL" />
        </geometry>
        <material name="grey">
            <color rgba="0.62745 0.62745 0.62745 1.0" />
        </material>
        </visual>
        <collision>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <geometry>
            <mesh filename="package://jazzy_gz/meshes/base_link.STL" />
        </geometry>
        </collision>
    </link>

    <gazebo reference="base_link">
        <material>Gazebo/Orange</material>
    </gazebo>

    <link name="left_wheel_link">
        <inertial>
        <origin xyz="-5.1909E-10 -0.0015399 7.1688E-10" rpy="0 0 0" />
        <mass value="0.035174" />
        <inertia ixx="1.5237e-05" ixy="-1.7432E-15" ixz="4.8399E-10" iyy="2.5786e-05" iyz="1.1685E-13" izz="1.5237e-05" />
        </inertial>
        <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <geometry>
            <mesh filename="package://jazzy_gz/meshes/left_wheel_link.STL" />
        </geometry>
        </visual>
        <collision>
        <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 0" />
        <geometry>
            <!-- <cylinder radius="0.033" length="0.025" /> -->
            <sphere radius="0.033" /> 
        </geometry>
        </collision>
    </link>

    <joint name="left_wheel_link_joint" type="continuous">
        <origin xyz="0 0.09 0" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="left_wheel_link" />
        <axis xyz="0 1 0" /> 
        <limit effort="0.05" velocity="10.0"/>
    </joint>

    <gazebo reference="left_wheel_link">
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <material>Gazebo/Black</material>
    </gazebo>

    <link name="right_wheel_link">
        <inertial>
        <origin xyz="8.4872E-10 0.0015399 2.5455E-10" rpy="0 0 0" />
        <mass value="0.035174" />
        <inertia ixx="1.5236e-05" ixy="-7.2194E-14" ixz="-2.0178E-11" iyy="2.5786e-05" iyz="-9.2017E-14" izz="1.5237e-05" />
        </inertial>
        <visual>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <geometry>
            <mesh filename="package://jazzy_gz/meshes/right_wheel_link.STL" />
        </geometry>
        </visual>
        <collision>
        <origin xyz="0.0 0.0 0.0" rpy="1.5708 0 0" />
        <geometry>
            <!-- <cylinder radius="0.033" length="0.025" /> -->
            <sphere radius="0.033" /> 
        </geometry>
        </collision>
    </link>

    <joint name="right_wheel_link_joint" type="continuous">
        <origin xyz="0 -0.09 0" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="right_wheel_link" />
        <axis xyz="0 1 0" />
        <limit effort="0.05" velocity="10.0"/>
    </joint>

    <gazebo reference="right_wheel_link">
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <material>Gazebo/Black</material>
    </gazebo>

    <!-- <gazebo reference="right_wheel">
        <material>Gazebo/Blue</material>
    </gazebo> -->


    <link name="front_caster_link">
        <inertial>
        <origin xyz="-2.35686364660759E-08 -5.30640420918008E-08 0.00860269" rpy="0 0 0" />
        <mass value="0.00233535" />
        <inertia ixx="6.25775e-08" ixy="-2.67819e-11" ixz="1.62405e-13" iyy="4.56804e-08" iyz="3.62663e-13" izz="7.82059e-08" />
        </inertial>
        <visual>
        <geometry><mesh filename="package://jazzy_gz/meshes/front_caster_link.STL" /></geometry>
        </visual>
        <collision>
        <origin xyz="0 0 0.009" rpy="0 0 0" />
        <geometry><sphere radius="0.009" /></geometry>
        </collision>
    </link>

    <joint name="front_caster_link_joint" type="fixed">
        <origin xyz="0.045 0 -0.033" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="front_caster_link" />
    </joint>

    <gazebo reference="front_caster_link">
        <material>Gazebo/Black</material>
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>


    <link name="back_caster_link">
        <inertial>
        <origin xyz="-2.3569E-08 -5.3064E-08 0.0086027" rpy="0 0 0" />
        <mass value="0.0023354" />
        <inertia ixx="6.2578e-08" ixy="-2.6782e-11" ixz="1.624e-13" iyy="4.568e-08" iyz="3.6266e-13" izz="7.8206e-08" />
        </inertial>
        <visual>
        <geometry><mesh filename="package://jazzy_gz/meshes/back_caster_link.STL" /></geometry>
        </visual>
        <collision>
        <origin xyz="0 0 0.009" rpy="0 0 0" />
        <geometry><sphere radius="0.009" /></geometry>
        </collision>
    </link>

    <joint name="back_caster_link_joint" type="fixed">
        <origin xyz="-0.045 0 -0.033" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="back_caster_link" />
    </joint>

    <gazebo reference="back_caster_link">
        <material>Gazebo/Black</material>
        <mu1 value="0.0"/>
        <mu2 value="0.0"/>
    </gazebo>

    <!-- <gazebo reference="caster_wheel">
        <material>Gazebo/Black</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo> -->

</robot>